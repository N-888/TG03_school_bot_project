# Игнорируем виртуальное окружение, чтобы не загружать служебные файлы в проектный архив или Git.
venv/

# Игнорируем локальный файл с секретами, чтобы случайно не показать токен бота.
.env

# Игнорируем автоматически создаваемую базу данных SQLite.
school_data.db

# Игнорируем кеш Python.
__pycache__/

# Игнорируем служебные pyc-файлы Python.
*.pyc

# Игнорируем системные файлы Windows и macOS, если они вдруг появятся.
.DS_Store
Thumbs.db